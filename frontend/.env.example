# Django REST API (phải kết thúc bằng /api)
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Origin backend cho ảnh /media/ — để trống sẽ suy ra từ VITE_API_BASE_URL
# VITE_MEDIA_BASE_URL=http://127.0.0.1:8000

# API tỉnh / huyện / xã Việt Nam
VITE_ADDRESS_API_BASE=https://provinces.open-api.vn/api/v2

# Tên cửa hàng (tiêu đề tab trình duyệt)
VITE_APP_NAME=PitchZone

# Ngưỡng miễn phí vận chuyển (VND) — khớp với backend
VITE_FREE_SHIPPING_THRESHOLD=2000000